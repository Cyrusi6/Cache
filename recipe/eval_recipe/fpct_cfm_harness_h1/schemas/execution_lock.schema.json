{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assets": {"additionalProperties": false, "properties": {"receiver_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}, "sender_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}, "sidecar_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}}, "required": ["receiver_sha256", "sender_sha256", "sidecar_sha256"], "type": "object"},
    "image": {"additionalProperties": false, "properties": {"reference": {"pattern": "^.+@sha256:[0-9a-f]{64}$", "type": "string"}, "source_tree_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}}, "required": ["reference", "source_tree_sha256"], "type": "object"},
    "kubernetes": {"additionalProperties": false, "properties": {"config_map": {"minLength": 1, "type": "string"}, "gpu_per_seed_pod": {"const": 2, "type": "integer"}, "namespace": {"minLength": 1, "type": "string"}, "node_name": {"minLength": 1, "type": "string"}}, "required": ["config_map", "gpu_per_seed_pod", "namespace", "node_name"], "type": "object"},
    "manifest_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "nested_confirmatory_manifest_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "protocol_id": {"const": "fpct_cfm_harness_h1_candidate_lock_projection_v1"},
    "run_uid": {"minLength": 1, "type": "string"},
    "schema_version": {"const": 1},
    "scientific_code_commit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "scientific_output": {"const": false},
    "shared_run_root": {"minLength": 1, "type": "string"},
    "source_lock_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "status": {"const": "H1_CONFIG_ONLY_CANDIDATE"},
    "training": {"additionalProperties": false, "properties": {"arm_order": {"additionalProperties": {"items": {"enum": ["c_pre", "c_post", "f"]}, "maxItems": 3, "minItems": 3, "type": "array"}, "type": "object"}, "examples": {"const": 2048, "type": "integer"}, "optimizer_steps": {"const": 64, "type": "integer"}, "seeds": {"items": {"maximum": 56, "minimum": 45, "type": "integer"}, "maxItems": 12, "minItems": 12, "type": "array"}, "world_size": {"const": 2, "type": "integer"}}, "required": ["arm_order", "examples", "optimizer_steps", "seeds", "world_size"], "type": "object"},
    "training_authorized": {"const": false}
  },
  "required": ["schema_version", "protocol_id", "status", "run_uid", "scientific_code_commit", "image", "manifest_sha256", "nested_confirmatory_manifest_sha256", "source_lock_sha256", "shared_run_root", "assets", "training", "kubernetes", "scientific_output", "training_authorized"],
  "type": "object"
}
